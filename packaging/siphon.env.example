# siphon REST API configuration
#
# Copy to /etc/siphon/siphon.env and edit, then:
#   systemctl enable --now siphon

# --- Network ---
DLPSCAN_API_HOST=127.0.0.1
DLPSCAN_API_PORT=8000

# --- Authentication ---
# Set a strong API key (>= 32 random bytes recommended).
# DLPSCAN_API_KEY=replace-me-with-a-real-key

# Map keys to roles (Admin / Analyst / Operator / Viewer).
# DLPSCAN_API_KEY_ROLES=admin-key:admin,analyst-key:analyst

# --- Rate limiting ---
DLPSCAN_API_RATE_LIMIT=100

# Optional: Redis-backed distributed rate limiter (requires
# the `redis-rate-limit` feature). Without this, each replica
# tracks counters independently.
# DLPSCAN_RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379

# --- EDM / LSH state ---
# DLPSCAN_EDM_STATE=/var/lib/siphon/edm.json
# DLPSCAN_LSH_STATE=/var/lib/siphon/lsh.json

# --- Audit ---
# DLPSCAN_AUDIT_LOG=/var/log/siphon/audit.log
# DLPSCAN_AUDIT_HMAC_KEY=replace-with-32-byte-secret

# --- Logging ---
RUST_LOG=info
